# ============================================================================
# CONTENT PIPELINE — CREDENTIALS (.env)
# ============================================================================
# Copy this file to `.env` and fill in the client's secrets. `.env` is
# gitignored and must NEVER be committed. See docs/DEPLOYMENT-SOP.md.
#
# Non-secret, per-client settings (ids, urls, timezones) live in
# `client_config.toml`, not here. This file is secrets only.
# ============================================================================

# --- WordPress -------------------------------------------------------------
# Application Password (NOT the WP login password). Generate at:
#   https://<client-site>/wp-admin/profile.php  ->  "Application Passwords"
# The pipeline pushes drafts via direct REST + a browser User-Agent because
# the WP MCP is firewalled (see memory/project_wp_mcp_blocked.md).
FM_WP_USER=
FM_WP_APP_PASSWORD=

# The WordPress user id every draft is authored under (post_author).
# Must match `wordpress.author_id` in client_config.toml.
FM_WP_AUTHOR_ID=

# --- Ahrefs ----------------------------------------------------------------
# Bearer token for the direct Ahrefs API v3 wrapper (tools/ahrefs.py), used by
# /schedule routines that lack the local Ahrefs MCP. Generate at:
#   https://ahrefs.com/api/profile
# Optional if you only ever run discovery through the local Ahrefs MCP.
AHREFS_API_TOKEN=

# --- GA4 (traffic-decay discovery) -----------------------------------------
# Absolute path to a Google service-account JSON with the Analytics Data API
# enabled and the service account added as a Viewer on the GA4 property.
# tools/ga4.py reads this; analytics-mcp is NOT used (it hangs).
# Leave blank to disable GA4 discovery (pipeline degrades gracefully).
GOOGLE_APPLICATION_CREDENTIALS=

# --- Devora Rank Math (optional) -------------------------------------------
# Only set if the Devora rank-math-api plugin is installed AND requires a key.
# By default the pipeline writes Rank Math meta via the WP REST `meta` field.
RANK_MATH_API_KEY=

# --- Images (disabled in v1) -----------------------------------------------
# v1 ships text-only drafts. When images are turned back on, set:
# PEXELS_API_KEY=
