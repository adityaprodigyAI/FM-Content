# WordPress credentials for Path B (GitHub Actions WAF unblock).
# Application Password (not the WP login password). Generate at:
#   https://firstmovers.ai/wp-admin/profile.php  →  "Application Passwords"
FM_WP_USER=
FM_WP_APP_PASSWORD=

# Optional override for the WordPress author. Defaults to omitting `author`
# in the create payload (WordPress assigns the API user as author).
# Set to 3 to explicitly force Josh McCoy as the author.
FM_WP_AUTHOR_ID=

# Pexels API key for image search.
# Get one at https://www.pexels.com/api/
PEXELS_API_KEY=

# Devora Rank Math plugin endpoint key (if the plugin requires auth).
# Currently uses WordPress REST nonce; set only if Devora is reconfigured.
RANK_MATH_API_KEY=
